{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MSTV Production OS",
  "version": "0.1.0",
  "identifier": "com.monstudiotv.mstvproductionos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:3000",
    "beforeBuildCommand": "npm run build:mobile",
    "frontendDist": "../out"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MSTV Production OS",
        "width": 960,
        "height": 1000,
        "minWidth": 960,
        "minHeight": 680,
        "resizable": true,
        "center": true,
        "dragDropEnabled": false,
        "backgroundColor": "#f7f9fb"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
